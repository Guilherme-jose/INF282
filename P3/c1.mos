    315415, 322000, 181935, 215323, 128530, 291625, 592410, 142759, 268777, 274324, 304268, 231567, 585866, 446027, 548460, 516574, 500269, 141973, 327322, 118920, 509971, 213199, 79283, 161786, 62606, 244022, 178772, 217273, 267450, 464530, 157508, 294592, 121640, 349996, 307652, 577562, 319336, 197044, 329810, 131148, 268897, 289429, 319771, 316625, 390923, 281565, 153365, 55137, 185330, 5, 91294, 490623,
