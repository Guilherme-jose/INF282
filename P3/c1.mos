model "Localizacao_PSA_Rondonia"
uses "mmxprs"

declarations
    ! 1. DEFINIÇÃO DE CONJUNTOS E PARÂMETROS
    N = 52 ! <--- ALTERE AQUI para o número total de cidades do seu anexo
    CIDADES = 1..N

    POP: array(CIDADES) of real
    DIST: array(CIDADES, CIDADES) of real

    CUSTO_FIXO: real
    CUSTO_TRANS: array(CIDADES, CIDADES) of real ! Matriz de custos pré-calculada

    ! 2. VARIÁVEIS DE DECISÃO
    y: array(CIDADES) of mpvar          ! 1 se abrir PSA na cidade j, 0 cc
    x: array(CIDADES, CIDADES) of mpvar ! proporção da cidade i atendida pelo PSA j
end-declarations

! ------------------------------------------------------------------
! INSERÇÃO DE DADOS (Substitua pelos dados do seu anexo)
! ------------------------------------------------------------------
