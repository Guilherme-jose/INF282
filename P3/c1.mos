    296066, 302626, 559434, 342492, 506615, 626724, 130033, 477827, 224632, 609500, 680092, 305375, 123489, 142982, 86083, 160692, 576075, 619425, 215121, 454051, 845318, 590632, 412287, 330076, 553293, 258838, 421199, 552531, 309563, 799661, 415834, 275014, 372212, 208974, 184376, 174818, 697056, 295644, 210195, 552760, 250387, 270080, 395802, 240958, 466504, 360883, 358117, 444596, 373119, 490623, 406167, 5]

! Alternativamente, você pode ler de um arquivo de dados descomentando abaixo:
! initializations from "dados.dat"
!     POP DIST
! end-initializations

! ------------------------------------------------------------------
! PRÉ-CÁLCULO DA MATRIZ DE CUSTOS DE TRANSPORTE
! ------------------------------------------------------------------
declarations
    dist_efetiva: real
end-declarations
    
forall(i in CIDADES, j in CIDADES) do
    ! Verifica a regra da distância mínima de 5 km
   

    if DIST(i,j) < 5.0 then
        dist_efetiva := 5.0
    else
        dist_efetiva := DIST(i,j)
    end-if

    ! Custo = (20% da Pop) * (Distância Ida e Volta) * R$ 0,35
    CUSTO_TRANS(i,j) := (0.20 * POP(i)) * (2.0 * dist_efetiva) * 0.35
end-do

! ------------------------------------------------------------------
! MODELAGEM
! ------------------------------------------------------------------
! Função Objetivo: Minimizar Custo Fixo + Custo de Transporte
CustoGlobal := sum(j in CIDADES) CUSTO_FIXO * y(j) +
               sum(i in CIDADES, j in CIDADES) CUSTO_TRANS(i,j) * x(i,j)

! Restrição 1: Toda cidade deve ter 100% de sua demanda atendida
forall(i in CIDADES)
    Atendimento(i) := sum(j in CIDADES) x(i,j) = 1

! Restrição 2: Só pode mandar paciente para PSA aberto
forall(i in CIDADES, j in CIDADES)
    Vinculo(i,j) := x(i,j) <= y(j)

! Natureza das variáveis
forall(j in CIDADES) y(j) is_binary
forall(i in CIDADES, j in CIDADES) do
    x(i,j) is_continuous ! Poderia ser binária, mas no UFLP naturaliza em 0 ou 1
    x(i,j) >= 0
    x(i,j) <= 1
end-do

! ------------------------------------------------------------------
! RESOLUÇÃO E EXIBIÇÃO DOS RESULTADOS
! ------------------------------------------------------------------
exportprob(EP_MIN, "modelo_rondonia.lp", CustoGlobal)
writeln("Matriz exportada com sucesso para 'modelo_rondonia.lp'!")

writeln("\n=======================================================")
writeln("SOLUÇÃO OTIMIZADA: REDE DE PRONTO SOCORROS (PSAs)")
writeln("=======================================================")
writeln("Custo Global Total: R$ ", getobjval)
writeln("-------------------------------------------------------")

writeln("PSAs a serem construídos:")
forall(j in CIDADES | getsol(y(j)) > 0.9) do
    writeln(" -> Abrir PSA na Cidade ", j)
end-do

writeln("-------------------------------------------------------")
writeln("Fluxo de Pacientes (Quem vai pra onde):")
forall(i in CIDADES) do
    forall(j in CIDADES | getsol(x(i,j)) > 0.9) do
        writeln(" -> Pacientes da Cidade ", i, " são atendidos no PSA da Cidade ", j)
    end-do
end-do
writeln("=======================================================\n")

end-model